{
  "name": "flux-converter",
  "version": "1.0.0",
  "description": "Cross-platform desktop app for local image and video conversion with Electron and FFmpeg.",
  "main": "src/main/index.js",
  "author": "Nikhil Rathore",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173/public/index.html && cross-env ELECTRON_START_URL=http://localhost:5173/public/index.html node scripts/launch-electron.js",
    "build:renderer": "vite build",
    "pack": "npm run build:renderer && electron-builder --config electron-builder.config.js --dir",
    "dist": "npm run build:renderer && electron-builder --config electron-builder.config.js"
  },
  "dependencies": {
    "electron-store": "11.0.2",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "2.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "tailwindcss": "4.2.2",
    "vite": "8.0.3",
    "wait-on": "9.0.4"
  }
}
